# Point at the Laravel backend. Phase 0 uses the existing hotel-tech backend;
# the wellness vertical shares the same API until Phase 1 introduces per-vertical
# routing. EXPO_PUBLIC_ prefix makes the value readable from client code.
EXPO_PUBLIC_API_URL=https://avatars.hotel-tech.ai

# Sentry — leave blank to skip Sentry at runtime. When you're ready to
# enable it:
#   1. npm install @sentry/react-native
#   2. npx expo run:android   (native module, needs a dev-client rebuild)
#   3. set EXPO_PUBLIC_SENTRY_DSN below
# initSentry() in src/sentry.ts is a safe no-op until all three are done.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
