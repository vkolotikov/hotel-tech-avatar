{
  "expo": {
    "name": "Hexalife",
    "slug": "health-app",
    "scheme": "hexalife",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f17"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hexalife.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow Hexalife to record voice messages for your avatar conversations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f17"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.hexalife.app",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7e22f92b-c4d5-47c8-94bc-1918a7a2f45d"
      }
    },
    "plugins": [
      "expo-secure-store",
      "@livekit/react-native-expo-plugin",
      [
        "expo-av",
        {
          "microphonePermission": "Allow Hexalife to record voice messages for your avatar conversations."
        }
      ]
    ],
    "owner": "hoteltechai"
  }
}
