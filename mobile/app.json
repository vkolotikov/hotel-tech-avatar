{
  "expo": {
    "name": "WellnessAI",
    "slug": "wellness-ai",
    "scheme": "wellnessai",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0b0f17"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.hoteltech.wellnessai",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Allow WellnessAI to record voice messages for your avatar conversations."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0b0f17"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "ai.hoteltech.wellnessai",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "7e22f92b-c4d5-47c8-94bc-1918a7a2f45d"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "Allow WellnessAI to record voice messages for your avatar conversations."
        }
      ]
    ]
  }
}
