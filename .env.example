APP_NAME="Hotel Avatar"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://avatar.hotel-tech.ai

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hotel_avatar
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# SaaS Core Auth
SAAS_PLATFORM_URL=https://saas.hotel-tech.ai
SAAS_JWT_SECRET=

CORS_ALLOWED_ORIGINS=https://avatar.hotel-tech.ai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_DEFAULT=gpt-4o
OPENAI_TIMEOUT_SECONDS=45
OPENAI_MAX_CONTEXT_MESSAGES=20
OPENAI_MAX_KNOWLEDGE_CHARS=12000
OPENAI_MAX_OUTPUT_TOKENS=220
OPENAI_TEMPERATURE=0.3
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Frontend
APP_FRONTEND_URL=https://avatar.hotel-tech.ai
